# Railway environment variables template — replace values in Railway dashboard
# Railway will provide `DATABASE_URL` automatically when a Postgres plugin is used.

# Django environment
DJANGO_ENV=production
# If you want to set a secret here for testing, otherwise set SECRET_KEY in Railway variables
SECRET_KEY=please-set-this-in-railway

# Optional: override Django debug (should be false in production)
DJANGO_DEBUG=False

# Email / other DB fallbacks (not required if Railway provides DATABASE_URL)
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=your_db_host
# DB_PORT=5432

# Any other secrets you need (SENTRY_DSN, THIRD_PARTY_API_KEY, etc.)
# SENTRY_DSN=
