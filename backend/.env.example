# ==========================================
# CONFIGURACIÓN BACKEND (Django)
# ==========================================

# Seguridad
# IMPORTANTE: Generar una nueva SECRET_KEY para producción
# Usar: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-tu-llave-secreta-generada-aqui-no-usar-en-produccion

# Debug (NUNCA establecer a True en producción)
DJANGO_DEBUG=True

# Hosts permitidos (separar con comas)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# CONFIGURACIÓN BASE DE DATOS (PostgreSQL)
# ==========================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bandwar_db
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura_aqui
DB_HOST=localhost
DB_PORT=5432

# ==========================================
# CONFIGURACIÓN CORS (Frontend)
# ==========================================
# Orígenes permitidos para acceso desde el frontend (separar con comas)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# CONFIGURACIÓN JWT (Autenticación)
# ==========================================
JWT_SECRET=tu-jwt-secret-key-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 1. NUNCA comitee este archivo con datos reales
# 2. Cada máquina de desarrollo debe tener su propio .env
# 3. El archivo .env debe estar en .gitignore (ya está)
# 4. Para producción, usar un gestor de secretos como AWS Secrets Manager, HashiCorp Vault, etc.
