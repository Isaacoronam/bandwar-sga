# Force LF for all text files and source/config files
* text=auto eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.bat text eol=lf

